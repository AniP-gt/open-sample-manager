{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Sample Manager",
  "version": "0.1.0",
  "identifier": "com.opensamplemanager.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev --prefix ui",
    "beforeBuildCommand": "npm run build --prefix ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Open Sample Manager",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
