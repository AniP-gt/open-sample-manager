{
  "identifier": "default",
  "description": "Default capabilities for Open Sample Manager",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-message",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "drag:allow-start-drag",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "**" }]
    }
  ]
}
